{
  "name": "react-any-shape-form",
  "author": "Eugene Trofimov",
  "license": "ISC",
  "version": "3.0.0",
  "description": "Small, type-friendly and flexible react form component.",
  "keywords": [
    "react",
    "form",
    "forms",
    "validation",
    "form-validation",
    "react-hooks",
    "hook",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deadrime/react-any-shape-form.git"
  },
  "homepage": "https://react-any-shape-form.vercel.app/",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run --typecheck"
  },
  "module": "dist/index.es.js",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "types": "./dist/src/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.es.js",
      "types": "./dist/src/core.d.ts"
    },
    "./array": {
      "import": "./dist/array.es.js",
      "types": "./dist/src/array.d.ts"
    },
    "./addons/array": {
      "import": "./dist/addons/array.es.js",
      "types": "./dist/src/addons/array.d.ts"
    },
    "./addons/nestedForm": {
      "import": "./dist/addons/nestedForm.es.js",
      "types": "./dist/src/addons/nestedForm.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "types": "dist/src/index.d.ts",
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@storybook/addon-docs": "9.1.17",
    "@storybook/addon-links": "9.1.17",
    "@storybook/addon-onboarding": "9.1.17",
    "@storybook/react-vite": "9.1.17",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^15.0.7",
    "@types/cross-spawn": "^6.0.6",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "eslint-plugin-storybook": "9.1.17",
    "jsdom": "^24.0.0",
    "prismjs": "^1.30.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-use": "^17.6.0",
    "storybook": "9.1.17",
    "tailwindcss": "^4.1.18",
    "terser": "^5.26.0",
    "typescript": "^5.0.2",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.6.0"
  }
}
